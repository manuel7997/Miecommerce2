<h1>Bienvenido a Botines Store ⚽</h1>

<!-- 🔃 Ordenamiento por precio -->
<div class="sort-controls">
    <span>Ordenar por precio:</span>
    <a href="/?sort=asc" class="btn-sort <%= sort === 'asc' ? 'btn-sort--active' : '' %>">⬆️ Menor a mayor</a>
    <a href="/?sort=desc" class="btn-sort <%= sort === 'desc' ? 'btn-sort--active' : '' %>">⬇️ Mayor a menor</a>
    <% if (sort) { %>
        <a href="/" class="btn-sort btn-sort--clear">✖ Quitar orden</a>
    <% } %>
</div>

<!-- ✨ Te puede interesar -->
<section class="products">
    <h2>✨ Te puede interesar</h2>
    <div class="product-list">
        <% products.forEach(product => { %>
            <%- include('../partials/productCard', { product }) %>
        <% }) %>
    </div>
</section>

<!-- 🔥 Los más pedidos -->
<section class="products">
    <h2>🔥 Los más pedidos</h2>
    <% if (featured.length > 0) { %>
        <div class="product-list">
            <% featured.forEach(product => { %>
                <%- include('../partials/productCard', { product }) %>
            <% }) %>
        </div>
    <% } else { %>
        <p>No hay productos destacados por el momento.</p>
    <% } %>
</section>

