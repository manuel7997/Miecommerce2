<section class="products">
    <h1>
        🔍 Resultados para: <span class="category-title">"<%= query %>"</span>
    </h1>

    <% if (results.length > 0) { %>
        <p class="search-count"><%= results.length %> producto<%= results.length !== 1 ? 's' : '' %> encontrado<%= results.length !== 1 ? 's' : '' %></p>
        <div class="product-list">
            <% results.forEach(product => { %>
                <%- include('../partials/productCard', { product }) %>
            <% }) %>
        </div>
    <% } else { %>
        <div class="cart-empty">
            <p>😕 No encontramos productos para "<%= query %>"</p>
            <a href="/" class="btn">⬅️ Volver al inicio</a>
        </div>
    <% } %>
</section>